{
  "name": "om-narayan-pandit-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:performance": "playwright test --config=e2e/performance.config.ts",
    "test:performance": "npm run test:coverage && npm run test:e2e:performance",
    "test:mutation": "stryker run",
    "test:mutation:report": "stryker run --reporters html,clear-text,progress"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "@types/nodemailer": "^6.4.15",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.408.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "resend": "^6.9.2",
    "tailwind-merge": "^2.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.6",
    "backstopjs": "^6.3.25",
    "eslint": "^9.14.0",
    "eslint-config-next": "16.2.6",
    "jsdom": "^25.0.0",
    "lighthouse": "^12.0.0",
    "playwright-lighthouse": "^2.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
}
