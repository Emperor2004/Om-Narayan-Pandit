{
  "name": "om-narayan-pandit-portfolio",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest --watch",
    "test:ci": "vitest --ci --coverage --watchAll=false",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:performance": "playwright test --config=e2e/performance.config.ts",
    "test:performance": "npm run test:coverage && npm run test:e2e:performance"
  },
  "dependencies": {
    "@react-three/drei": "^9.88.17",
    "@react-three/fiber": "^8.15.12",
    "@types/nodemailer": "^6.4.15",
    "@types/three": "^0.184.1",
    "autoprefixer": "^10.4.24",
    "clsx": "^2.1.1",
    "critters": "^0.0.23",
    "framer-motion": "^11.3.8",
    "lucide-react": "^0.408.0",
    "next": "^14.2.15",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^6.9.2",
    "tailwind-merge": "^2.4.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/node": "^20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.3",
    "@vitest/coverage-v8": "^2.0.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^13.2.15",
    "jsdom": "^25.0.0",
    "lighthouse": "^12.0.0",
    "playwright-lighthouse": "^2.0.0",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.0.5"
  }
